# Caddyfile — TLS reverse proxy for voice-to-vault OpenClaw instance
# Caddy automatically provisions and renews Let's Encrypt TLS certificates.
# Replace vault.example.com with your actual domain pointed at the Hetzner VPS IP.

{$OPENCLAW_DOMAIN:vault.example.com} {
    reverse_proxy openclaw:8080

    # Restrict webhook path — only Telegram IPs can call it
    # Telegram IP ranges: https://core.telegram.org/bots/webhooks#the-short-version
    @webhook path /webhook/telegram
    handle @webhook {
        reverse_proxy openclaw:8080
    }

    # Metrics endpoint — localhost only (not exposed through Caddy)
    @metrics path /metrics
    respond @metrics 403

    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}
