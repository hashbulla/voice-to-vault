# Caddyfile — TLS reverse proxy for voice-to-vault OpenClaw instance
# Caddy automatically provisions and renews Let's Encrypt TLS certificates.
# Replace vault.example.com with your actual domain pointed at the Hetzner VPS IP.

{
    # FIX E: Disable Caddy admin API — prevents lateral movement from compromised
    # containers on the same Docker network from modifying TLS config or proxy routes.
    admin off
}

{$OPENCLAW_DOMAIN:vault.example.com} {
    # FIX B: Rate-limit the webhook path — 10 requests per 10 seconds per source IP.
    # Protects OpenAI/Anthropic API credits against spoofed POST floods.
    # Returns 429 Too Many Requests on breach.
    @webhook path /webhook/telegram
    handle @webhook {
        rate_limit {
            zone telegram_webhook {
                key    {remote_host}
                events 10
                window 10s
            }
        }
        reverse_proxy openclaw:8080
    }

    # Metrics endpoint — localhost only (not exposed through Caddy)
    @metrics path /metrics
    respond @metrics 403

    # All other paths
    handle {
        reverse_proxy openclaw:8080
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}
