# =============================================================================
# voice-to-vault — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in all values before starting.
# Never commit .env to version control.
# =============================================================================
# SECURITY: After copying to .env, run:
# chmod 600 .env && chown root:root .env
# Never commit .env. Never log env vars.
# Verify: stat -c "%a" .env  (must output 600)
# =============================================================================

# -----------------------------------------------------------------------------
# TELEGRAM
# -----------------------------------------------------------------------------

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your personal Telegram numeric user ID (get it from @userinfobot)
# Only messages from this user ID will be processed — all others are rejected
TELEGRAM_ALLOWED_USER_ID=

# -----------------------------------------------------------------------------
# OPENAI — WHISPER TRANSCRIPTION
# -----------------------------------------------------------------------------

OPENAI_API_KEY=

# ISO 639-1 language code for Whisper. Override per-note with caption "!en"
WHISPER_LANGUAGE=fr

# Vocabulary hint for Whisper — improves recognition of domain-specific terms
# Extend this list as your vocabulary grows (see docs/WHISPER_PROMPT.md)
WHISPER_PROMPT=DevSecOps, Kubernetes, K3s, RKE2, OpenShift, Helm, Terraform, GitOps, CI/CD, Kali Linux, Debian, WSL2, Docker, Podman, Koyeb, Fly.io, Cloudflare, Python, Go, TypeScript, FastAPI, GitHub, GitLab, Claude Code, Claude Haiku, Anthropic, OpenAI, OpenClaw, Obsidian, MCP, RAG, LangGraph, Whisper, Telegram, BotFather, webhook, OSINT, pentest, Red Team, CVE, RBAC, mTLS, zero-trust, SOC, SIEM, K8s, microservices, Freelance, GTM, SaaS, Rennes, Bretagne

# -----------------------------------------------------------------------------
# ANTHROPIC — CLASSIFICATION
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=

# Always use the latest Haiku model for cost-efficient classification
CLAUDE_MODEL=claude-haiku-4-5

# -----------------------------------------------------------------------------
# GITHUB — VAULT REPOSITORY
# -----------------------------------------------------------------------------

# Target private vault repository (owner/repo format)
VAULT_REPO=hashbulla/second-brain-vault

# Absolute path to the SSH Deploy Key with write access to VAULT_REPO
# Generated during setup — see hetzner/setup.sh and README.md deployment guide
VAULT_DEPLOY_KEY_PATH=/root/.ssh/vault_deploy_key

# Branch to commit vault notes to
VAULT_BRANCH=main

# -----------------------------------------------------------------------------
# NIGHTLY AGENT
# -----------------------------------------------------------------------------

# Absolute path for nightly processing log output
NIGHTLY_AGENT_LOG=/var/log/voice-to-vault/nightly.log

# Timezone for cron scheduling (Europe/Paris = CET/CEST)
NIGHTLY_CRON_TZ=Europe/Paris

# -----------------------------------------------------------------------------
# OPENCLAW
# -----------------------------------------------------------------------------

# Required. Generate with: openssl rand -hex 32
# Register with: make register-webhook (passed to Telegram API)
# Telegram sends this as X-Telegram-Bot-Api-Secret-Token header.
OPENCLAW_WEBHOOK_SECRET=

# Port OpenClaw listens on inside the container
OPENCLAW_PORT=8080

# Public HTTPS URL where Telegram will POST webhook events
# Must be reachable from the internet. Include protocol, no trailing slash.
# Example: https://vault.yourdomain.com
OPENCLAW_WEBHOOK_URL=

# Domain for Caddy TLS certificate (without protocol)
# Must have an A record pointing to the Hetzner VPS IP
# Example: vault.yourdomain.com
OPENCLAW_DOMAIN=

# Local vault clone path (used by git_writer.py and run.sh)
# Default: /home/openclaw/vault — matches Docker named volume mount point
VAULT_CLONE_DIR=/home/openclaw/vault

# -----------------------------------------------------------------------------
# OPTIONAL — ADVANCED
# -----------------------------------------------------------------------------

# Set to "1" to enable verbose pipeline logging (stdout)
DEBUG=0

# Maximum audio file size accepted (bytes). Default: 25MB (Whisper limit)
MAX_AUDIO_BYTES=26214400

# Git author metadata written on vault commits
GIT_AUTHOR_NAME=voice-to-vault[bot]
GIT_AUTHOR_EMAIL=bot@voice-to-vault.local
