# =============================================================================
# voice-to-vault — Crontab Example (Hetzner CX22)
# =============================================================================
# Install with:
#   crontab -l | cat - hetzner/crontab.example | crontab -
# Or edit manually:
#   crontab -e
#
# The TZ= prefix sets the timezone for each cron entry only.
# This ensures runs fire at Paris time regardless of the system default (UTC).
# =============================================================================

# voice-to-vault nightly vault processor — morning run
0 6 * * * TZ=Europe/Paris /opt/voice-to-vault/agents/nightly_processor/run.sh >> /var/log/voice-to-vault/cron.log 2>&1

# voice-to-vault nightly vault processor — afternoon run
0 14 * * * TZ=Europe/Paris /opt/voice-to-vault/agents/nightly_processor/run.sh >> /var/log/voice-to-vault/cron.log 2>&1

# voice-to-vault nightly vault processor — nightly run (primary)
0 23 * * * TZ=Europe/Paris /opt/voice-to-vault/agents/nightly_processor/run.sh >> /var/log/voice-to-vault/cron.log 2>&1

# =============================================================================
# Optional: weekly log rotation (Sunday 01:00 UTC)
# =============================================================================
# 0 1 * * 0 find /var/log/voice-to-vault -name "*.log" -mtime +30 -delete
